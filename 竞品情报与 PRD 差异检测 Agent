<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>竞品情报与PRD差异检测 Agent</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e1a;
    --bg-surface: #111827;
    --bg-card: #1a2236;
    --bg-card-hover: #1f2a42;
    --accent: #00d4aa;
    --accent-dim: #00d4aa33;
    --accent-warn: #ff6b6b;
    --accent-info: #4ecdc4;
    --accent-gold: #ffd93d;
    --text-primary: #e8ecf4;
    --text-secondary: #8892a8;
    --text-muted: #4a5568;
    --border: #2a3450;
    --border-active: #00d4aa55;
    --gradient-1: linear-gradient(135deg, #00d4aa 0%, #007cf0 100%);
    --gradient-2: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    --shadow-lg: 0 20px 60px rgba(0,0,0,0.4);
    --shadow-glow: 0 0 40px rgba(0,212,170,0.15);
    --radius: 12px;
    --radius-sm: 8px;
    --radius-xs: 6px;
    --font-sans: 'Noto Sans SC', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse at 15% 10%, rgba(0,212,170,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 85% 80%, rgba(102,126,234,0.05) 0%, transparent 50%);
    pointer-events: none; z-index: 0;
  }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

  /* ── Layout ── */
  .app { position: relative; z-index: 1; max-width: 1440px; margin: 0 auto; padding: 24px 32px 60px; }

  /* ── Header ── */
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0 32px; border-bottom: 1px solid var(--border); margin-bottom: 32px;
  }
  .header-left { display: flex; align-items: center; gap: 16px; }
  .logo {
    width: 48px; height: 48px; border-radius: var(--radius);
    background: var(--gradient-1); display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 900; color: var(--bg); letter-spacing: -1px;
    box-shadow: 0 4px 20px rgba(0,212,170,0.3);
  }
  .header-title h1 { font-size: 20px; font-weight: 700; letter-spacing: -0.5px; }
  .header-title p { font-size: 13px; color: var(--text-secondary); margin-top: 2px; }
  .header-right { display: flex; align-items: center; gap: 12px; }
  .badge {
    font-family: var(--font-mono); font-size: 11px; padding: 5px 12px;
    border-radius: 20px; border: 1px solid var(--border);
    color: var(--text-secondary); background: var(--bg-surface);
  }
  .badge.live { border-color: var(--accent); color: var(--accent); }
  .badge.live::before { content:''; display:inline-block; width:6px; height:6px; border-radius:50%; background:var(--accent); margin-right:6px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* ── Pipeline Visualization ── */
  .pipeline {
    display: flex; align-items: center; gap: 0; margin-bottom: 36px;
    padding: 24px 28px; background: var(--bg-surface); border-radius: var(--radius);
    border: 1px solid var(--border); overflow-x: auto;
  }
  .pipeline-step {
    display: flex; align-items: center; gap: 10px; padding: 10px 18px;
    border-radius: var(--radius-sm); font-size: 13px; font-weight: 500;
    color: var(--text-muted); white-space: nowrap; transition: all 0.4s;
    cursor: default; position: relative;
  }
  .pipeline-step .step-num {
    width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 12px; font-weight: 600;
    border: 2px solid var(--border); color: var(--text-muted); transition: all 0.4s;
  }
  .pipeline-step.active { color: var(--text-primary); background: var(--bg-card); }
  .pipeline-step.active .step-num { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
  .pipeline-step.done { color: var(--accent); }
  .pipeline-step.done .step-num { border-color: var(--accent); color: var(--bg); background: var(--accent); }
  .pipeline-arrow {
    font-size: 18px; color: var(--text-muted); margin: 0 4px; flex-shrink: 0;
    transition: color 0.4s;
  }
  .pipeline-arrow.lit { color: var(--accent); }

  /* ── Grid ── */
  .main-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
  }
  .full-span { grid-column: 1 / -1; }

  /* ── Cards ── */
  .card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 24px; transition: border-color 0.3s;
  }
  .card:hover { border-color: var(--border-active); }
  .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .card-header h2 { font-size: 15px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .card-header h2 .icon { font-size: 18px; }
  .card-header .tag {
    font-family: var(--font-mono); font-size: 10px; padding: 3px 8px;
    border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .tag-agent { background: rgba(0,212,170,0.15); color: var(--accent); }
  .tag-auto { background: rgba(255,217,61,0.15); color: var(--accent-gold); }

  /* ── Inputs ── */
  textarea {
    width: 100%; min-height: 200px; padding: 14px 16px;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text-primary);
    font-family: var(--font-sans); font-size: 13px; line-height: 1.7;
    resize: vertical; outline: none; transition: border-color 0.3s;
  }
  textarea:focus { border-color: var(--accent); }
  textarea::placeholder { color: var(--text-muted); }

  input[type="text"] {
    width: 100%; padding: 10px 14px;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text-primary);
    font-family: var(--font-sans); font-size: 13px; outline: none;
    transition: border-color 0.3s;
  }
  input[type="text"]:focus { border-color: var(--accent); }
  input[type="text"]::placeholder { color: var(--text-muted); }

  /* ── Buttons ── */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 22px; border: none; border-radius: var(--radius-sm);
    font-family: var(--font-sans); font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all 0.25s; letter-spacing: 0.2px;
  }
  .btn-primary {
    background: var(--gradient-1); color: var(--bg);
    box-shadow: 0 4px 16px rgba(0,212,170,0.25);
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(0,212,170,0.35); }
  .btn-primary:active { transform: translateY(0); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
  .btn-secondary {
    background: var(--bg-surface); color: var(--text-secondary);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover { border-color: var(--text-muted); color: var(--text-primary); }

  .btn-group { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }

  /* ── Log / Output ── */
  .log-container {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 16px; max-height: 400px;
    overflow-y: auto; font-family: var(--font-mono); font-size: 12px;
    line-height: 1.9;
  }
  .log-line { display: flex; gap: 8px; opacity: 0; animation: logIn 0.3s forwards; }
  .log-line .time { color: var(--text-muted); flex-shrink: 0; }
  .log-line .agent { color: var(--accent); flex-shrink: 0; font-weight: 600; }
  .log-line .msg { color: var(--text-secondary); }
  .log-line .msg strong { color: var(--text-primary); font-weight: 500; }
  .log-line.warn .msg { color: var(--accent-warn); }
  .log-line.success .msg { color: var(--accent); }
  @keyframes logIn { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:translateY(0); } }

  /* ── Results Table ── */
  .diff-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
  .diff-table th {
    text-align: left; padding: 10px 14px; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .diff-table td {
    padding: 12px 14px; font-size: 13px; border-bottom: 1px solid rgba(42,52,80,0.5);
    vertical-align: top;
  }
  .diff-table tr { transition: background 0.2s; }
  .diff-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .severity {
    display: inline-block; padding: 2px 8px; border-radius: 4px;
    font-size: 11px; font-weight: 600; font-family: var(--font-mono);
  }
  .severity.high { background: rgba(255,107,107,0.15); color: var(--accent-warn); }
  .severity.medium { background: rgba(255,217,61,0.15); color: var(--accent-gold); }
  .severity.low { background: rgba(78,205,196,0.15); color: var(--accent-info); }

  /* ── Stats Row ── */
  .stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;
  }
  .stat-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 18px 20px; text-align: center;
    transition: all 0.3s;
  }
  .stat-card:hover { border-color: var(--accent-dim); transform: translateY(-2px); }
  .stat-value {
    font-family: var(--font-mono); font-size: 28px; font-weight: 700;
    background: var(--gradient-1); -webkit-background-clip: text;
    -webkit-text-fill-color: transparent; background-clip: text;
  }
  .stat-label { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

  /* ── Report Section ── */
  .report-content {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 24px; line-height: 1.8;
    font-size: 13.5px; color: var(--text-secondary); max-height: 500px; overflow-y: auto;
  }
  .report-content h3 { color: var(--text-primary); font-size: 15px; margin: 20px 0 8px; }
  .report-content h3:first-child { margin-top: 0; }
  .report-content ul { padding-left: 20px; margin: 8px 0; }
  .report-content li { margin: 4px 0; }
  .report-content .highlight { color: var(--accent); font-weight: 500; }
  .report-content .warn-text { color: var(--accent-warn); font-weight: 500; }

  /* ── Skeleton Loading ── */
  .skeleton {
    background: linear-gradient(90deg, var(--bg-surface) 25%, var(--bg-card) 50%, var(--bg-surface) 75%);
    background-size: 200% 100%; animation: shimmer 1.5s infinite;
    border-radius: var(--radius-xs); height: 16px; margin: 8px 0;
  }
  .skeleton.w60 { width: 60%; }
  .skeleton.w80 { width: 80%; }
  .skeleton.w40 { width: 40%; }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

  /* ── Progress Bar ── */
  .progress-bar {
    width: 100%; height: 4px; background: var(--border);
    border-radius: 2px; overflow: hidden; margin: 16px 0;
  }
  .progress-bar .fill {
    height: 100%; border-radius: 2px; background: var(--gradient-1);
    transition: width 0.5s ease; width: 0%;
  }

  /* ── Entry Animations ── */
  .fade-up { opacity: 0; transform: translateY(16px); animation: fadeUp 0.5s ease forwards; }
  .fade-up:nth-child(2) { animation-delay: 0.08s; }
  .fade-up:nth-child(3) { animation-delay: 0.16s; }
  .fade-up:nth-child(4) { animation-delay: 0.24s; }
  .fade-up:nth-child(5) { animation-delay: 0.32s; }
  @keyframes fadeUp { to { opacity:1; transform:translateY(0); } }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .app { padding: 16px; }
    .main-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .pipeline { padding: 16px; }
  }
</style>
</head>
<body>
<div class="app">

  <!-- Header -->
  <header class="header fade-up">
    <div class="header-left">
      <div class="logo">CI</div>
      <div class="header-title">
        <h1>竞品情报与 PRD 差异检测 Agent</h1>
        <p>Multi-Agent Pipeline · Competitive Intelligence × PRD Gap Analysis</p>
      </div>
    </div>
    <div class="header-right">
      <span class="badge live" id="statusBadge">就绪</span>
      <span class="badge">v2.1</span>
    </div>
  </header>

  <!-- Pipeline -->
  <div class="pipeline fade-up" id="pipeline">
    <div class="pipeline-step" data-step="0"><span class="step-num">1</span> PRD 解析 Agent</div>
    <span class="pipeline-arrow">→</span>
    <div class="pipeline-step" data-step="1"><span class="step-num">2</span> 竞品情报采集 Agent</div>
    <span class="pipeline-arrow">→</span>
    <div class="pipeline-step" data-step="2"><span class="step-num">3</span> 差异检测 Agent</div>
    <span class="pipeline-arrow">→</span>
    <div class="pipeline-step" data-step="3"><span class="step-num">4</span> 报告生成 Agent</div>
  </div>

  <!-- Stats -->
  <div class="stats-row fade-up" id="statsRow" style="display:none;">
    <div class="stat-card"><div class="stat-value" id="statFeatures">-</div><div class="stat-label">PRD 功能点</div></div>
    <div class="stat-card"><div class="stat-value" id="statCompetitors">-</div><div class="stat-label">竞品功能点</div></div>
    <div class="stat-card"><div class="stat-value" id="statGaps">-</div><div class="stat-label">差异 / 缺口</div></div>
    <div class="stat-card"><div class="stat-value" id="statCoverage">-</div><div class="stat-label">覆盖率</div></div>
  </div>

  <!-- Main Grid -->
  <div class="main-grid">

    <!-- PRD Input -->
    <div class="card fade-up">
      <div class="card-header">
        <h2><span class="icon">📄</span> PRD 产品需求文档</h2>
        <span class="tag tag-agent">Agent 1 解析</span>
      </div>
      <textarea id="prdInput" placeholder="在此粘贴您的 PRD 内容...&#10;&#10;示例：&#10;【产品名称】智能客服系统 v3.0&#10;【核心功能】&#10;1. 多轮对话引擎：支持上下文理解，记忆窗口 20 轮&#10;2. 知识库管理：支持 PDF/Word/网页导入，自动向量化&#10;3. 工单自动创建：识别用户意图后自动生成工单&#10;4. 数据看板：实时会话量、满意度、解决率统计&#10;5. 多渠道接入：支持微信、网页、APP、电话"></textarea>
      <div class="btn-group">
        <button class="btn btn-secondary" onclick="loadSamplePRD()">载入示例 PRD</button>
      </div>
    </div>

    <!-- Competitor Intel Input -->
    <div class="card fade-up">
      <div class="card-header">
        <h2><span class="icon">🔍</span> 竞品情报数据</h2>
        <span class="tag tag-agent">Agent 2 采集</span>
      </div>
      <textarea id="competitorInput" placeholder="在此粘贴竞品情报信息...&#10;&#10;示例：&#10;【竞品名称】某头部 SaaS 客服产品&#10;【已知功能】&#10;1. 多轮对话：支持 50 轮上下文，含情感分析&#10;2. 知识库：支持 200+ 文件格式，自动摘要&#10;3. 工单系统：自动分配 + SLA 监控 + 升级机制&#10;4. 数据分析：支持自定义报表 + 导出&#10;5. 全渠道：微信/钉钉/飞书/网页/APP/电话/邮件&#10;6. AI 辅助坐席：实时话术推荐&#10;7. 合规审计：对话记录加密存储，满足等保三级"></textarea>
      <div class="btn-group">
        <button class="btn btn-secondary" onclick="loadSampleCompetitor()">载入示例情报</button>
      </div>
    </div>

    <!-- Agent Log -->
    <div class="card full-span fade-up">
      <div class="card-header">
        <h2><span class="icon">⚡</span> Agent 执行日志</h2>
        <div style="display:flex;align-items:center;gap:12px;">
          <span class="tag tag-auto" id="logTag" style="display:none;">自动运行中</span>
          <button class="btn btn-primary" id="runBtn" onclick="runPipeline()">
            ▶ 启动检测流程
          </button>
        </div>
      </div>
      <div class="progress-bar"><div class="fill" id="progressFill"></div></div>
      <div class="log-container" id="logContainer">
        <div class="log-line"><span class="time">--:--:--</span><span class="agent">[系统]</span><span class="msg">等待输入 PRD 和竞品情报后启动检测流程...</span></div>
      </div>
    </div>

    <!-- Diff Results -->
    <div class="card full-span fade-up" id="diffCard" style="display:none;">
      <div class="card-header">
        <h2><span class="icon">📊</span> 差异检测结果</h2>
        <span class="tag tag-agent">Agent 3 分析</span>
      </div>
      <div style="overflow-x:auto;">
        <table class="diff-table" id="diffTable">
          <thead>
            <tr>
              <th>功能维度</th>
              <th>PRD 现状</th>
              <th>竞品能力</th>
              <th>差异类型</th>
              <th>严重度</th>
              <th>建议</th>
            </tr>
          </thead>
          <tbody id="diffBody"></tbody>
        </table>
      </div>
    </div>

    <!-- Report -->
    <div class="card full-span fade-up" id="reportCard" style="display:none;">
      <div class="card-header">
        <h2><span class="icon">📝</span> 差异分析报告</h2>
        <span class="tag tag-agent">Agent 4 生成</span>
      </div>
      <div class="report-content" id="reportContent"></div>
      <div class="btn-group">
        <button class="btn btn-primary" onclick="exportReport()">↓ 导出报告</button>
        <button class="btn btn-secondary" onclick="copyReport()">复制 Markdown</button>
      </div>
    </div>
  </div>
</div>

<script>
// ─── State ───
let isRunning = false;

// ─── Sample Data ───
const samplePRD = `【产品名称】智能客服系统 v3.0
【版本】3.0 Beta
【核心功能模块】

1. 多轮对话引擎
   - 支持上下文理解，记忆窗口 20 轮
   - 意图识别准确率目标 ≥ 92%
   - 支持中文、英文双语

2. 知识库管理
   - 支持 PDF / Word / 网页链接导入
   - 自动向量化存储
   - 知识库容量上限 10 万条

3. 工单自动创建
   - 识别用户投诉/售后意图后自动生成工单
   - 支持工单分类和优先级标记

4. 数据看板
   - 实时会话量统计
   - 用户满意度评分
   - 问题解决率趋势图

5. 多渠道接入
   - 微信公众号 / 小程序
   - 网页在线客服
   - APP SDK
   - 电话语音（IVR）

6. 权限管理
   - 管理员 / 坐席 / 只读 三级角色
   - 操作日志审计`;

const sampleCompetitor = `【竞品名称】某头部 SaaS 智能客服平台（行业 Top 3）
【情报来源】官网文档 + 产品试用 + 行业报告
【已知功能清单】

1. 多轮对话引擎
   - 支持 50 轮上下文记忆
   - 内置情感分析模块，可检测愤怒/焦虑/满意等情绪
   - 支持中/英/日/韩等 12 种语言

2. 知识库管理
   - 支持 200+ 文件格式（含音视频转录）
   - 自动摘要 + 知识图谱可视化
   - 知识库容量无上限（按存储计费）

3. 工单系统
   - 自动分配 + SLA 监控 + 升级机制
   - 与 Jira / 飞书 / 钉钉深度集成
   - 工单生命周期全流程追踪

4. 数据分析
   - 支持自定义 SQL 报表
   - 数据导出（CSV / Excel / API）
   - 竞品舆情监控看板

5. 全渠道接入
   - 微信 / 钉钉 / 飞书 / 网页 / APP / 电话 / 邮件 / WhatsApp / Telegram
   - 统一消息路由引擎

6. AI 辅助坐席
   - 实时话术推荐
   - 自动生成会话摘要
   - 客户画像弹屏

7. 合规与安全
   - 对话记录加密存储（AES-256）
   - 满足等保三级 / SOC 2
   - 数据驻留区域可选

8. 开放平台
   - RESTful API + Webhook
   - 自定义插件市场
   - 低代码流程编排`;

function loadSamplePRD() {
  document.getElementById('prdInput').value = samplePRD;
}
function loadSampleCompetitor() {
  document.getElementById('competitorInput').value = sampleCompetitor;
}

// ─── Helpers ───
function timeStr() {
  return new Date().toLocaleTimeString('zh-CN', {hour12:false});
}

function addLog(agent, msg, cls='') {
  const c = document.getElementById('logContainer');
  const line = document.createElement('div');
  line.className = 'log-line ' + cls;
  line.innerHTML = `<span class="time">${timeStr()}</span><span class="agent">[${agent}]</span><span class="msg">${msg}</span>`;
  c.appendChild(line);
  c.scrollTop = c.scrollHeight;
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function setPipelineStep(idx) {
  document.querySelectorAll('.pipeline-step').forEach((el,i) => {
    el.classList.remove('active','done');
    if (i < idx) el.classList.add('done');
    if (i === idx) el.classList.add('active');
  });
  document.querySelectorAll('.pipeline-arrow').forEach((el,i) => {
    el.classList.toggle('lit', i < idx);
  });
}

function setProgress(pct) {
  document.getElementById('progressFill').style.width = pct + '%';
}

// ─── Core: PRD Parsing ───
function parsePRD(text) {
  const features = [];
  const lines = text.split('\n');
  let current = null;
  for (const raw of lines) {
    const line = raw.trim();
    // Match numbered items like "1. 多轮对话引擎" or "1、xxx"
    const mainMatch = line.match(/^(\d+)[.、]\s*(.+)/);
    if (mainMatch) {
      if (current) features.push(current);
      current = { name: mainMatch[2].replace(/[：:]/g,'').trim(), details: [] };
    } else if (current && line.startsWith('-') || current && line.startsWith('·')) {
      current.details.push(line.replace(/^[-·]\s*/, ''));
    }
  }
  if (current) features.push(current);
  return features;
}

// ─── Core: Competitor Parsing ───
function parseCompetitor(text) {
  const features = [];
  const lines = text.split('\n');
  let current = null;
  for (const raw of lines) {
    const line = raw.trim();
    const mainMatch = line.match(/^(\d+)[.、]\s*(.+)/);
    if (mainMatch) {
      if (current) features.push(current);
      current = { name: mainMatch[2].replace(/[：:]/g,'').trim(), details: [] };
    } else if (current && (line.startsWith('-') || line.startsWith('·'))) {
      current.details.push(line.replace(/^[-·]\s*/, ''));
    }
  }
  if (current) features.push(current);
  return features;
}

// ─── Core: Diff Detection (keyword + semantic heuristic) ───
function detectDiffs(prdFeatures, compFeatures) {
  const diffs = [];

  // Build keyword maps
  const compKeywords = compFeatures.map(f => ({
    feature: f,
    keywords: extractKeywords(f.name + ' ' + f.details.join(' '))
  }));
  const prdKeywords = prdFeatures.map(f => ({
    feature: f,
    keywords: extractKeywords(f.name + ' ' + f.details.join(' '))
  }));

  // For each PRD feature, find best competitor match
  const matchedComp = new Set();

  for (const prd of prdFeatures) {
    const pk = extractKeywords(prd.name + ' ' + prd.details.join(' '));
    let bestMatch = null, bestScore = 0;

    for (let i = 0; i < compKeywords.length; i++) {
      if (matchedComp.has(i)) continue;
      const score = jaccardSimilarity(pk, compKeywords[i].keywords);
      if (score > bestScore) { bestScore = score; bestMatch = i; }
    }

    if (bestScore > 0.25 && bestMatch !== null) {
      matchedComp.add(bestMatch);
      const comp = compFeatures[bestMatch];
      // Compare details
      const compDetailText = comp.details.join(' ');
      const prdDetailText = prd.details.join(' ');
      const gapDetails = [];

      // Check for capacity / quantitative gaps
      const compNums = compDetailText.match(/\d+/g) || [];
      const prdNums = prdDetailText.match(/\d+/g) || [];
      if (compNums.length > prdNums.length) {
        gapDetails.push('竞品有更多量化指标');
      }

      // Check for extra details in competitor
      const compExtra = comp.details.filter(d => {
        const dk = extractKeywords(d);
        return !prd.details.some(pd => jaccardSimilarity(extractKeywords(pd), dk) > 0.3);
      });

      if (compExtra.length > 0) {
        const severity = compExtra.length >= 3 ? 'high' : compExtra.length >= 2 ? 'medium' : 'low';
        diffs.push({
          dimension: prd.name,
          prdStatus: summarize(prd.details, 40),
          compStatus: summarize(comp.details, 40),
          type: '功能差距',
          severity: severity,
          advice: `竞品在此模块多出 ${compExtra.length} 项能力：${compExtra.slice(0,2).join('；')}`,
          prdFeature: prd,
          compFeature: comp
        });
      } else {
        diffs.push({
          dimension: prd.name,
          prdStatus: summarize(prd.details, 40),
          compStatus: summarize(comp.details, 40),
          type: '基本对齐',
          severity: 'low',
          advice: '功能覆盖基本一致，可关注细节体验优化',
          prdFeature: prd,
          compFeature: comp
        });
      }
    } else {
      // PRD has feature, competitor doesn't match well — possibly unique or competitor lacks it
      diffs.push({
        dimension: prd.name,
        prdStatus: summarize(prd.details, 40),
        compStatus: '未发现对应功能',
        type: 'PRD 独有',
        severity: 'low',
        advice: '此为 PRD 差异化优势，建议保持并强化',
        prdFeature: prd,
        compFeature: null
      });
    }
  }

  // Competitor features not matched to any PRD feature = PRD gaps
  for (let i = 0; i < compFeatures.length; i++) {
    if (!matchedComp.has(i)) {
      const comp = compFeatures[i];
      diffs.push({
        dimension: comp.name,
        prdStatus: '未覆盖',
        compStatus: summarize(comp.details, 40),
        type: 'PRD 缺口',
        severity: comp.details.length >= 3 ? 'high' : 'medium',
        advice: `竞品具备此能力但 PRD 未规划，建议评估是否纳入 Roadmap`,
        prdFeature: null,
        compFeature: comp
      });
    }
  }

  return diffs;
}

function extractKeywords(text) {
  // Simple tokenization: split by common delimiters, filter short tokens
  return new Set(
    text.replace(/[：:，,。.、；;（）()【】\[\]\/\\]/g, ' ')
      .split(/\s+/)
      .filter(w => w.length >= 2)
  );
}

function jaccardSimilarity(setA, setB) {
  const intersection = new Set([...setA].filter(x => setB.has(x)));
  const union = new Set([...setA, ...setB]);
  return union.size === 0 ? 0 : intersection.size / union.size;
}

function summarize(details, maxLen) {
  if (!details || details.length === 0) return '-';
  const text = details.join('；');
  return text.length > maxLen ? text.slice(0, maxLen) + '...' : text;
}

// ─── Core: Report Generation ───
function generateReport(prdFeatures, compFeatures, diffs) {
  const high = diffs.filter(d => d.severity === 'high');
  const medium = diffs.filter(d => d.severity === 'medium');
  const low = diffs.filter(d => d.severity === 'low');
  const gaps = diffs.filter(d => d.type === 'PRD 缺口');
  const aligned = diffs.filter(d => d.type === '基本对齐');
  const unique = diffs.filter(d => d.type === 'PRD 独有');
  const coverage = prdFeatures.length > 0
    ? Math.round((aligned.length + unique.length) / (aligned.length + unique.length + gaps.length) * 100)
    : 0;

  let report = '';
  report += `<h3>一、执行摘要</h3>`;
  report += `<p>本次差异检测覆盖 <span class="highlight">${prdFeatures.length} 项 PRD 功能模块</span> 与 <span class="highlight">${compFeatures.length} 项竞品能力</span>，`;
  report += `共识别出 <span class="warn-text">${diffs.length} 项差异</span>，其中高严重度 ${high.length} 项、中严重度 ${medium.length} 项、低严重度 ${low.length} 项。</p>`;
  report += `<p>PRD 对竞品的功能覆盖率约为 <span class="highlight">${coverage}%</span>。</p>`;

  report += `<h3>二、关键缺口（高优先级）</h3>`;
  if (high.length === 0) {
    report += `<p>未发现高严重度差距，整体对齐情况良好。</p>`;
  } else {
    report += `<ul>`;
    high.forEach(d => {
      report += `<li><span class="warn-text">[${d.type}] ${d.dimension}</span>：${d.advice}</li>`;
    });
    report += `</ul>`;
  }

  report += `<h3>三、中等差距</h3>`;
  if (medium.length === 0) {
    report += `<p>未发现中等严重度差距。</p>`;
  } else {
    report += `<ul>`;
    medium.forEach(d => {
      report += `<li><strong>${d.dimension}</strong>（${d.type}）：${d.advice}</li>`;
    });
    report += `</ul>`;
  }

  report += `<h3>四、已对齐与差异化优势</h3>`;
  report += `<p><strong>基本对齐模块（${aligned.length} 项）：</strong>`;
  report += aligned.map(d => d.dimension).join('、') || '无';
  report += `</p>`;
  report += `<p><strong>PRD 独有优势（${unique.length} 项）：</strong>`;
  report += unique.map(d => d.dimension).join('、') || '无';
  report += `</p>`;

  report += `<h3>五、建议行动项</h3>`;
  report += `<ul>`;
  report += `<li><strong>短期（1-2 周）：</strong>针对 ${high.length} 项高严重度缺口，组织产品评审会，确认是否纳入当前迭代。</li>`;
  report += `<li><strong>中期（1 个月）：</strong>对 ${medium.length} 项中等差距进行竞品深度调研，输出详细功能对比文档。</li>`;
  report += `<li><strong>长期：</strong>建立定期竞品监控机制，建议每两周自动运行一次差异检测。</li>`;
  report += `</ul>`;

  return report;
}

// ─── Pipeline Runner ───
async function runPipeline() {
  if (isRunning) return;
  const prdText = document.getElementById('prdInput').value.trim();
  const compText = document.getElementById('competitorInput').value.trim();

  if (!prdText || !compText) {
    alert('请先输入 PRD 内容和竞品情报数据');
    return;
  }

  isRunning = true;
  const btn = document.getElementById('runBtn');
  btn.disabled = true;
  btn.textContent = '⏳ 运行中...';
  document.getElementById('statusBadge').textContent = '运行中';
  document.getElementById('statusBadge').classList.add('live');
  document.getElementById('logTag').style.display = 'inline-block';
  document.getElementById('logContainer').innerHTML = '';
  document.getElementById('diffCard').style.display = 'none';
  document.getElementById('reportCard').style.display = 'none';
  document.getElementById('statsRow').style.display = 'none';
  setProgress(0);

  // Step 1: PRD Parsing
  setPipelineStep(0);
  addLog('PRD-Parser', '开始解析 PRD 文档...');
  await sleep(600);
  addLog('PRD-Parser', '识别文档结构，提取功能模块...', '');
  await sleep(500);
  const prdFeatures = parsePRD(prdText);
  addLog('PRD-Parser', `解析完成，共识别 <strong>${prdFeatures.length} 个功能模块</strong>`, 'success');
  prdFeatures.forEach((f, i) => {
    addLog('PRD-Parser', `模块 ${i+1}：<strong>${f.name}</strong>（${f.details.length} 条细则）`);
  });
  setProgress(25);
  await sleep(400);

  // Step 2: Competitor Parsing
  setPipelineStep(1);
  addLog('Intel-Crawler', '开始解析竞品情报数据...', '');
  await sleep(600);
  addLog('Intel-Crawler', '提取竞品功能清单与能力描述...', '');
  await sleep(500);
  const compFeatures = parseCompetitor(compText);
  addLog('Intel-Crawler', `解析完成，共识别 <strong>${compFeatures.length} 个竞品能力点</strong>`, 'success');
  compFeatures.forEach((f, i) => {
    addLog('Intel-Crawler', `能力 ${i+1}：<strong>${f.name}</strong>（${f.details.length} 条细则）`);
  });
  setProgress(50);
  await sleep(400);

  // Step 3: Diff Detection
  setPipelineStep(2);
  addLog('Diff-Engine', '启动差异检测引擎...', '');
  await sleep(400);
  addLog('Diff-Engine', '执行关键词匹配 + 语义相似度计算...', '');
  await sleep(700);
  const diffs = detectDiffs(prdFeatures, compFeatures);
  addLog('Diff-Engine', `检测完成，共发现 <strong>${diffs.length} 项差异</strong>`, 'success');
  const highCount = diffs.filter(d=>d.severity==='high').length;
  const medCount = diffs.filter(d=>d.severity==='medium').length;
  const lowCount = diffs.filter(d=>d.severity==='low').length;
  addLog('Diff-Engine', `高严重度: <strong>${highCount}</strong> | 中严重度: <strong>${medCount}</strong> | 低严重度: <strong>${lowCount}</strong>`);
  setProgress(75);
  await sleep(400);

  // Render diff table
  const tbody = document.getElementById('diffBody');
  tbody.innerHTML = '';
  diffs.forEach(d => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="font-weight:500;color:var(--text-primary)">${d.dimension}</td>
      <td>${d.prdStatus}</td>
      <td>${d.compStatus}</td>
      <td>${d.type}</td>
      <td><span class="severity ${d.severity}">${d.severity === 'high' ? '高' : d.severity === 'medium' ? '中' : '低'}</span></td>
      <td style="font-size:12px;color:var(--text-secondary)">${d.advice}</td>
    `;
    tbody.appendChild(tr);
  });
  document.getElementById('diffCard').style.display = 'block';
  document.getElementById('diffCard').scrollIntoView({behavior:'smooth', block:'start'});

  // Stats
  const coverage = prdFeatures.length > 0
    ? Math.round((diffs.filter(d=>d.type==='基本对齐').length + diffs.filter(d=>d.type==='PRD 独有').length) / (diffs.length) * 100)
    : 0;
  document.getElementById('statFeatures').textContent = prdFeatures.length;
  document.getElementById('statCompetitors').textContent = compFeatures.length;
  document.getElementById('statGaps').textContent = diffs.filter(d=>d.type!=='基本对齐'&&d.type!=='PRD 独有').length;
  document.getElementById('statCoverage').textContent = coverage + '%';
  document.getElementById('statsRow').style.display = 'grid';

  await sleep(400);

  // Step 4: Report Generation
  setPipelineStep(3);
  addLog('Report-Agent', '开始生成差异分析报告...', '');
  await sleep(500);
  const report = generateReport(prdFeatures, compFeatures, diffs);
  addLog('Report-Agent', '报告生成完成', 'success');
  setProgress(100);

  document.getElementById('reportContent').innerHTML = report;
  document.getElementById('reportCard').style.display = 'block';

  // Mark all done
  setPipelineStep(4);
  document.getElementById('statusBadge').textContent = '完成';
  document.getElementById('logTag').style.display = 'none';
  btn.disabled = false;
  btn.textContent = '▶ 重新运行';
  isRunning = false;
}

// ─── Export ───
function exportReport() {
  const content = document.getElementById('reportContent').innerText;
  const blob = new Blob([content], {type:'text/plain;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = '竞品差异分析报告_' + new Date().toISOString().slice(0,10) + '.txt';
  a.click(); URL.revokeObjectURL(url);
}

function copyReport() {
  const content = document.getElementById('reportContent').innerText;
  navigator.clipboard.writeText(content).then(() => {
    alert('报告内容已复制到剪贴板');
  });
}
